APP_NAME=Esporteam
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=esporteam-postgres
DB_PORT=5433
DB_DATABASE=esporteam_back
DB_USERNAME=esporteam
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FEATURE_EVENT_SOCIAL_CHAT=false
FILESYSTEM_DISK=local
CONVERSATION_MEDIA_DISK=local
CONVERSATION_MEDIA_CLAMAV_SOCKET=tcp://clamav:3310
CONVERSATION_MEDIA_IMAGE_MAGICK_BINARY=magick
CONVERSATION_MEDIA_AWS_REGION=us-east-1
CONVERSATION_MEDIA_AWS_ACCESS_KEY_ID=
CONVERSATION_MEDIA_AWS_SECRET_ACCESS_KEY=
CONVERSATION_MEDIA_MODERATION_MIN_CONFIDENCE=80
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

DISCOVERY_CACHE_TTL_SECONDS=30
DISCOVERY_RATE_LIMIT_PER_MINUTE=30
MAP_RATE_LIMIT_PER_MINUTE=60

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# JWT (RS256 público — chave compartilhada com esporteam-auth/esporteam-workspace)
JWT_PUBLIC_KEY=/var/www/keys/public.pem

# Service-to-service URLs (intra-docker network)
AUTH_SERVICE_URL=http://esporteam-auth:8000
WORKSPACE_SERVICE_URL=http://esporteam-workspace:8000

# LLM hub (#7)
LLM_DRIVER=anthropic
LLM_CLUSTERING_PROMPT=clustering_v1
LLM_CLUSTERING_MODEL=claude-haiku-4-5-20251001
LLM_MONTHLY_BUDGET=5000000
LLM_PRECLUSTER_THRESHOLD=0.85
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_URL=https://api.openai.com/v1
BIO_ASSISTED_PROVIDER=openai
BIO_ASSISTED_MODEL=gpt-4o-mini
BIO_ASSISTED_PROMPT_VERSION=bio_v1
BIO_ASSISTED_RATE_MAX=5
BIO_ASSISTED_RATE_DECAY_SECONDS=3600

# Reverb (#7 — realtime clustering events)
REVERB_APP_ID=esporteam
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=esporteam-back
REVERB_PORT=8080
REVERB_SCHEME=http
