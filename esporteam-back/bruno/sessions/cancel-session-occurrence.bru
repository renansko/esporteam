  token: {{jwtToken}}
}

body:json {
  {
    "version": 1,
    "reason": "Quadra interditada"
  }
}

docs {
  Cancela somente a ocorrência, mantendo a série ativa e a ocorrência visível como cancelada para participantes.
}
