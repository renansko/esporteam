meta {
  name: List Participant Sessions
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/profile/sessions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

docs {
  GET /api/profile/sessions lista sessoes em que Perfil Esportivo autenticado possui participacao.

  Ordenacao: starts_at/id desc. Limite: 50 itens.
  Inclui joined, approved, interested, invited, declined, removed e left.
  Front normaliza left fora da primeira interface de Partidas; vazio retorna data: [].
}
